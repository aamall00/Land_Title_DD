# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key    # Never expose this to the browser
SUPABASE_STORAGE_BUCKET=land-documents

# ── Anthropic / Claude ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# ── OCR Provider ─────────────────────────────────────────────────────────────
# Options: 'tesseract' (local, free) | 'textract' (AWS, better accuracy)
OCR_PROVIDER=tesseract

# ── AWS Textract (only if OCR_PROVIDER=textract) ─────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
MAX_UPLOAD_MB=50
